# AGATA — Environment Variables
# Copy this file to .env.local and fill in your values

# Mapbox Public Token (required)
# Get yours at: https://account.mapbox.com/access-tokens/
# Note: Use a PUBLIC token (starts with pk.) — this is safe to expose in browser
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# App URL (optional — for metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
